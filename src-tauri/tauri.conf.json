{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LogRadar",
  "version": "0.1.0",
  "identifier": "com.logradar.app",
  "build": { "beforeDevCommand": "npm run dev", "beforeBuildCommand": "npm run build", "frontendDist": "../dist", "devUrl": "http://localhost:5173" },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LogRadar",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
